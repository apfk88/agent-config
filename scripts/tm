#!/usr/bin/env bash
set -euo pipefail

log() { printf '%s\n' "$*"; }
err() { printf 'ERROR: %s\n' "$*" >&2; }
usage() {
  cat <<'USAGE'
Usage:
  tm new [path|url|name] [branch]    Create repo session (agent-0/agent-1/server/bash)
  tm new <slug>#<branch>        Shorthand for repo + branch
  tm attach            List tmux sessions and attach
  tm list              List tmux sessions
  tm killall [--yes]   Kill all tmux sessions (asks confirmation unless --yes)
  tm kill [name]       Pick a tmux session to kill (or pass name)
  tm rename [new]      Rename current session (or pick)
  tm exit              Detach from current tmux session
  tm help              Show this help
USAGE
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || { err "Missing required command: $1"; exit 1; }
}

DEV_DIR_DEFAULT="$HOME/dev"

repo_root_if_inside() {
  if git rev-parse --show-toplevel >/dev/null 2>&1; then
    git rev-parse --show-toplevel
    return 0
  fi
  return 1
}

in_agent_config_repo() {
  local repo_dir="$1"
  local root
  root="$(git -C "$repo_dir" rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -z "$root" ]; then
    return 1
  fi
  if [ -f "$root/scripts/bootstrap.sh" ] && [ -f "$root/scripts/tm" ]; then
    return 0
  fi
  return 1
}

is_url_like() {
  case "$1" in
    http://*|https://*|git@*|ssh://*|*github.com*|*gitlab.com*|*bitbucket.org*) return 0 ;;
    */*) return 0 ;;
    *) return 1 ;;
  esac
}

repo_name_from() {
  local input="$1"
  input="${input##*/}"
  input="${input%.git}"
  printf '%s' "$input"
}

sanitize_session_name() {
  local input="$1"
  local out=""
  local char=""
  local i

  for ((i = 0; i < ${#input}; i += 1)); do
    char="${input:i:1}"
    case "$char" in
      [A-Za-z0-9_.-]) out+="$char" ;;
      *) out+="-" ;;
    esac
  done

  while [[ "$out" == *--* ]]; do
    out="${out//--/-}"
  done
  out="${out#-}"
  out="${out%-}"

  printf '%s' "${out:-repo}"
}

session_name_from_repo() {
  local repo_dir="$1"
  sanitize_session_name "$(basename "$repo_dir")"
}

expand_path() {
  local input="$1"
  case "$input" in
    "~") printf '%s' "$HOME" ;;
    "~/"*) printf '%s/%s' "$HOME" "${input#~/}" ;;
    *) printf '%s' "$input" ;;
  esac
}

is_local_path_hint() {
  case "$1" in
    ./*|../*|/*|~/*|*/*/*) return 0 ;;
    *) return 1 ;;
  esac
}

confirm_yes() {
  local prompt="$1"
  local answer=""

  if [ -t 0 ]; then
    read -r -p "$prompt [y/N]: " answer
  else
    printf '%s [y/N]: ' "$prompt" >&2
    if ! read -r answer; then
      return 1
    fi
  fi

  case "$answer" in
    y|Y|yes|YES|Yes) return 0 ;;
    *) return 1 ;;
  esac
}

create_repo() {
  local dest="$1"
  local branch="${2:-}"

  mkdir -p "$dest"

  if [ -n "$branch" ]; then
    if ! git -C "$dest" init -b "$branch" >/dev/null 2>&1; then
      git -C "$dest" init >/dev/null
      git -C "$dest" checkout -b "$branch" >/dev/null
    fi
  else
    git -C "$dest" init >/dev/null
  fi

  printf '%s' "$(cd "$dest" && pwd -P)"
}

resolve_new_repo_path() {
  local input="$1"
  local dev_dir="$2"

  if is_local_path_hint "$input"; then
    printf '%s' "$(expand_path "$input")"
  else
    printf '%s/%s' "$dev_dir" "$input"
  fi
}

create_repo_from_input() {
  local input="$1"
  local dev_dir="$2"
  local branch="$3"
  local repo_path

  repo_path="$(resolve_new_repo_path "$input" "$dev_dir")"
  if [ -e "$repo_path" ]; then
    err "Path exists and is not a directory: $repo_path"
    exit 1
  fi
  if confirm_yes "Create new git repo at $repo_path?"; then
    printf '%s\t%s' "$(create_repo "$repo_path" "$branch")" "$branch"
    return 0
  fi

  err "Not a repo path or URL: $input"
  exit 1
}

clone_repo() {
  local input="$1"
  local url="$input"
  local dest_base="$2"
  local branch="${3:-}"

  if [[ "$input" =~ ^[^/]+/[^/]+$ ]]; then
    url="https://github.com/${input}.git"
  fi

  local name
  name="$(repo_name_from "$input")"

  mkdir -p "$dest_base"
  local dest="${dest_base}/${name}"

  if [ -e "$dest" ]; then
    err "Destination exists: ${dest}"
    exit 1
  fi

  if [ -n "$branch" ]; then
    log "Cloning ${url} (branch ${branch}) -> ${dest}"
    git clone --branch "$branch" --single-branch "$url" "$dest" >/dev/null
  else
    log "Cloning ${url} -> ${dest}"
    git clone "$url" "$dest" >/dev/null
  fi
  printf '%s' "$dest"
}

pick_repo() {
  local input="${1:-}"
  local branch_override="${2:-}"
  local branch=""
  local dev_dir="${DEV_DIR:-$DEV_DIR_DEFAULT}"

  if [ -n "$branch_override" ] && [[ "$input" == *"#"* ]]; then
    err "Use either <repo>#<branch> or <repo> <branch>"
    exit 1
  fi

  if [ -z "$branch_override" ] && [[ "$input" == *"#"* ]]; then
    branch="${input#*#}"
    input="${input%%#*}"
    if [ -z "$branch" ]; then
      err "Branch missing after #"
      exit 1
    fi
  else
    branch="$branch_override"
  fi

  if [ -n "$input" ]; then
    if [[ "$input" != */* ]]; then
      local dev_path="${dev_dir}/${input}"
      if [ -d "$dev_path" ]; then
        printf '%s\t%s' "$(cd "$dev_path" && pwd -P)" "$branch"
        return 0
      fi
    fi
    if [ -d "$input" ]; then
      printf '%s\t%s' "$(cd "$input" && pwd -P)" "$branch"
      return 0
    fi
    if is_local_path_hint "$input"; then
      create_repo_from_input "$input" "$dev_dir" "$branch"
      return 0
    fi
    if is_url_like "$input"; then
      local base
      read -r -p "Clone into (default: $HOME/dev): " base
      base="${base:-$HOME/dev}"
      printf '%s\t%s' "$(clone_repo "$input" "$base" "$branch")" "$branch"
      return 0
    fi
    create_repo_from_input "$input" "$dev_dir" "$branch"
    return 0
  fi

  local inside=""
  if inside="$(repo_root_if_inside)"; then
    if ! in_agent_config_repo "$inside"; then
      printf '%s\t%s' "$inside" "$branch"
      return 0
    fi
  fi

  read -r -p "Repo path, GitHub URL, or new project name: " input
  if [ -z "$input" ]; then
    err "No input"
    exit 1
  fi

  if [ -d "$input" ]; then
    printf '%s\t%s' "$(cd "$input" && pwd -P)" "$branch"
    return 0
  fi

  if is_local_path_hint "$input"; then
    create_repo_from_input "$input" "$dev_dir" "$branch"
    return 0
  fi

  if is_url_like "$input"; then
    local base
    read -r -p "Clone into (default: $HOME/dev): " base
    base="${base:-$HOME/dev}"
    printf '%s\t%s' "$(clone_repo "$input" "$base" "$branch")" "$branch"
    return 0
  fi

  create_repo_from_input "$input" "$dev_dir" "$branch"
  return 0
}

attach_or_switch() {
  local session="$1"
  local target
  target="$(tmux_session_target "$session")"

  if [ -n "${TMUX-}" ]; then
    tmux switch-client -t "$target"
  else
    tmux attach -t "$target"
  fi
}

get_sessions() {
  tmux list-sessions -F '#S' 2>/dev/null || true
}

tmux_session_target() {
  printf '=%s' "$1"
}

tmux_window_target() {
  printf '=%s:%s' "$1" "$2"
}

tmux_session_exists() {
  tmux has-session -t "$(tmux_session_target "$1")" 2>/dev/null
}

menu_out() {
  if [ -t 1 ]; then
    printf '%s\n' "$*"
  else
    printf '%s\n' "$*" >&2
  fi
}

choose_session() {
  local sessions
  sessions="$(get_sessions)"
  if [ -z "$sessions" ]; then
    err "No tmux sessions"
    exit 1
  fi

  menu_out "Active sessions:"
  local i=1
  while IFS= read -r s; do
    menu_out "  [$i] $s"
    i=$((i + 1))
  done <<<"$sessions"

  local choice
  read -r -p "Choose session # or name: " choice
  if [ -z "$choice" ]; then
    err "Invalid choice"
    exit 1
  fi

  local target=""
  if [[ "$choice" =~ ^[0-9]+$ ]]; then
    local idx=1
    while IFS= read -r s; do
      if [ "$idx" -eq "$choice" ]; then
        target="$s"
        break
      fi
      idx=$((idx + 1))
    done <<<"$sessions"
  else
    while IFS= read -r s; do
      if [ "$s" = "$choice" ]; then
        target="$s"
        break
      fi
    done <<<"$sessions"
  fi

  if [ -z "$target" ]; then
    err "Invalid choice"
    exit 1
  fi

  printf '%s' "$target"
}

attach_session() {
  local target
  target="$(choose_session)"
  attach_or_switch "$target"
}

list_sessions() {
  local sessions
  sessions="$(get_sessions)"
  if [ -z "$sessions" ]; then
    err "No tmux sessions"
    exit 1
  fi

  log "Sessions:"
  local i=1
  while IFS= read -r s; do
    printf '  [%s] %s\n' "$i" "$s"
    i=$((i + 1))
  done <<<"$sessions"

}

kill_session() {
  local target="${1:-}"
  if [ -n "$target" ]; then
    if ! tmux_session_exists "$target"; then
      err "No such session: $target"
      exit 1
    fi
  else
    target="$(choose_session)"
  fi
  tmux kill-session -t "$(tmux_session_target "$target")"
  log "Killed: $target"
}

kill_all_sessions() {
  local yes_flag="${1:-}"
  local sessions
  sessions="$(get_sessions)"
  if [ -z "$sessions" ]; then
    err "No tmux sessions"
    exit 1
  fi

  if [ "$yes_flag" != "--yes" ] && [ "$yes_flag" != "-y" ]; then
    menu_out "Sessions to kill:"
    while IFS= read -r s; do
      menu_out "  - $s"
    done <<<"$sessions"
    if ! confirm_yes "Kill all tmux sessions?"; then
      log "Canceled"
      return 0
    fi
  fi

  tmux kill-server
  log "Killed all tmux sessions"
}

current_session() {
  tmux display-message -p '#S' 2>/dev/null || true
}

rename_session() {
  local new_name="${1:-}"
  local old_name=""

  if [ -n "$new_name" ] && [ -n "${TMUX-}" ]; then
    old_name="$(current_session)"
  elif [ -n "$new_name" ] && [ -z "${TMUX-}" ]; then
    old_name="$(choose_session)"
  else
    old_name="$(choose_session)"
    read -r -p "New name: " new_name
  fi

  if [ -z "$new_name" ]; then
    err "No new name"
    exit 1
  fi

  new_name="$(sanitize_session_name "$new_name")"
  if [ -z "$old_name" ]; then
    err "No current session"
    exit 1
  fi

  if tmux_session_exists "$new_name"; then
    err "Session exists: $new_name"
    exit 1
  fi

  tmux rename-session -t "$(tmux_session_target "$old_name")" "$new_name"
  log "Renamed: $old_name -> $new_name"
}

switch_branch() {
  local repo_dir="$1"
  local branch="$2"
  local current_branch=""

  if [ -z "$branch" ]; then
    return 0
  fi

  if [ -n "$(git -C "$repo_dir" status --porcelain)" ]; then
    err "Dirty repo, won’t checkout branch: ${branch}"
    exit 1
  fi

  current_branch="$(git -C "$repo_dir" symbolic-ref --short HEAD 2>/dev/null || true)"
  if [ "$current_branch" = "$branch" ]; then
    return 0
  fi

  if git -C "$repo_dir" show-ref --verify --quiet "refs/heads/$branch"; then
    git -C "$repo_dir" checkout "$branch"
    return 0
  fi

  if git -C "$repo_dir" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    git -C "$repo_dir" checkout -b "$branch" "origin/$branch"
    return 0
  fi

  err "Branch not found: $branch"
  exit 1
}

new_session() {
  local repo_dir
  local branch="${2:-}"
  local picked=""
  local picked_branch=""
  picked="$(pick_repo "${1:-}" "$branch")"
  IFS=$'\t' read -r repo_dir picked_branch <<<"$picked"

  if ! git -C "$repo_dir" rev-parse --show-toplevel >/dev/null 2>&1; then
    err "Not a git repo: ${repo_dir}"
    exit 1
  fi

  switch_branch "$repo_dir" "$picked_branch"

  local session
  session="$(session_name_from_repo "$repo_dir")"

  if tmux_session_exists "$session"; then
    attach_or_switch "$session"
    return 0
  fi

  tmux new-session -d -s "$session" -c "$repo_dir" -n agent-0
  tmux new-window -t "$(tmux_window_target "$session" 1)" -n agent-1 -c "$repo_dir"
  tmux new-window -t "$(tmux_window_target "$session" 2)" -n server -c "$repo_dir"
  tmux new-window -t "$(tmux_window_target "$session" 3)" -n bash -c "$repo_dir"
  tmux set-option -t "$(tmux_session_target "$session")" status-position top
  tmux set-option -t "$(tmux_session_target "$session")" status-style "fg=white,bg=black"
  tmux set-option -t "$(tmux_session_target "$session")" status-left "#[fg=black,bg=colour11,bold] #S #[default] "
  tmux set-option -t "$(tmux_session_target "$session")" status-right ""
  tmux set-option -t "$(tmux_session_target "$session")" window-status-format "#[fg=brightwhite,bg=colour237] #I:#W #[default]"
  tmux set-option -t "$(tmux_session_target "$session")" window-status-current-style "fg=black,bg=colour10,bold"
  tmux set-option -t "$(tmux_session_target "$session")" window-status-current-format " #I:#W "
  tmux set-option -t "$(tmux_session_target "$session")" mouse on
  tmux select-window -t "$(tmux_window_target "$session" 0)"

  attach_or_switch "$session"
}

run_self_tests() {
  local actual=""

  actual="$(sanitize_session_name "my repo:api")"
  [ "$actual" = "my-repo-api" ] || { err "sanitize_session_name failed: $actual"; exit 1; }

  actual="$(sanitize_session_name "!!!")"
  [ "$actual" = "repo" ] || { err "sanitize_session_name fallback failed: $actual"; exit 1; }

  actual="$(session_name_from_repo "/tmp/work/My Repo: API")"
  [ "$actual" = "My-Repo-API" ] || { err "session_name_from_repo failed: $actual"; exit 1; }

  actual="$(repo_name_from "https://github.com/apfk88/agent-config.git")"
  [ "$actual" = "agent-config" ] || { err "repo_name_from URL failed: $actual"; exit 1; }

  actual="$(tmux_session_target "agent-config")"
  [ "$actual" = "=agent-config" ] || { err "tmux_session_target failed: $actual"; exit 1; }

  actual="$(tmux_window_target "agent-config" "2")"
  [ "$actual" = "=agent-config:2" ] || { err "tmux_window_target failed: $actual"; exit 1; }

  log "ok"
}

main() {
  local cmd="${1:-new}"
  case "$cmd" in
    -h|--help|help)
      usage
      return 0
      ;;
    self-test)
      run_self_tests
      return 0
      ;;
  esac

  need_cmd tmux
  need_cmd git

  case "$cmd" in
    new)
      shift
      new_session "${1:-}" "${2:-}"
      ;;
    attach)
      attach_session
      ;;
    exit)
      if [ -n "${TMUX-}" ]; then
        tmux detach-client
      else
        err "Not in tmux"
        exit 1
      fi
      ;;
    list)
      list_sessions
      ;;
    killall)
      shift
      kill_all_sessions "${1:-}"
      ;;
    kill)
      shift
      kill_session "${1:-}"
      ;;
    rename)
      shift
      rename_session "${1:-}"
      ;;
    *)
      err "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
